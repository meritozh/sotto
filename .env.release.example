# Copy this file to .env.release (gitignored) and fill in your values.
#
# Generate an App Store Connect API key:
#   App Store Connect → Users and Access → Integrations → App Store Connect API
#   Role: App Manager (or Admin)
#
# Place the downloaded AuthKey_<KEY_ID>.p8 at one of these paths
# (altool searches them in this order):
#   ./private_keys/AuthKey_<KEY_ID>.p8
#   ~/private_keys/AuthKey_<KEY_ID>.p8
#   ~/.private_keys/AuthKey_<KEY_ID>.p8
#   ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8     ← recommended

ASC_KEY_ID=ABCD1234EF
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
